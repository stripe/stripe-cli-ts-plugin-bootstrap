#!/usr/bin/env bash
# Generate TypeScript classes from .proto files using ts-proto.
# Looks for .proto files in protos/ directory and outputs to src/proto/ (or specified directory).
#
# Usage:
#   npx stripe-cli-gen-proto [output-dir]
#
# Examples:
#   npx stripe-cli-gen-proto                 # outputs to src/proto/
#   npx stripe-cli-gen-proto src/grpc/proto  # outputs to src/grpc/proto/

set -eu -o pipefail

OUTPUT_DIR="${1:-src/proto}"

if [ ! -d protos ]; then
  echo "❌ No protos/ directory found. Create a protos/ directory with your .proto files."
  exit 1
fi

# Check if there are any proto files
if ! find protos -name "*.proto" -print -quit | grep -q .; then
  echo "❌ No .proto files found in protos/ directory."
  exit 1
fi

echo "🔧 Generating TypeScript from protos/ → $OUTPUT_DIR"

# Remove existing proto files and re-create dir.
rm -rf "$OUTPUT_DIR"
mkdir -p "$OUTPUT_DIR"

find protos -name "*.proto" -print0 | xargs -0 ./node_modules/.bin/protoc \
  --proto_path=protos \
  --plugin=./node_modules/.bin/protoc-gen-ts_proto \
  --ts_proto_out="$OUTPUT_DIR" \
  --ts_proto_opt=esModuleInterop=true \
  --ts_proto_opt=lowerCaseServiceMethods=true \
  --ts_proto_opt=outputClientImpl=false \
  --ts_proto_opt=addGrpcMetadata=true \
  --ts_proto_opt=outputServices=grpc-js,generic-definitions

echo "✅ Proto generation complete: $OUTPUT_DIR"
